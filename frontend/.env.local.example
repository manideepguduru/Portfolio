# Instagram Graph API Configuration
# To get live Instagram follower count, add your Instagram access token

# Get your access token from Meta Developer Console:
# 1. Go to https://developers.facebook.com/apps/
# 2. Create/select your app
# 3. Go to Settings > Basic to get your App ID and App Secret
# 4. Create a system user access token with instagram_business_account scope
# 5. Copy the token below

VITE_INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_token_here

# Example with token (DO NOT commit actual token to git):
# VITE_INSTAGRAM_ACCESS_TOKEN=EAABSg...

# Note: The token refreshes typically last 60 days on Instagram Graph API
# Keep .env.local in .gitignore to prevent accidentally committing tokens
